NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
# 32+ random bytes hex; set via vercel env add for all environments
PARATUS_INGEST_SECRET=
# Resend transactional email — used by SLA breach cron (apps/web/app/api/cron/sla-check)
# Resend Dashboard → API Keys → Create. Mark Sensitive in Vercel.
RESEND_API_KEY=
# Verified Resend sender domain (e.g. alerts@paratus.group). Use onboarding@resend.dev
# only for local smoke. See .planning/phases/06-production-hardening/06-USER-SETUP.md.
SLA_ALERT_FROM_EMAIL=
# Bearer secret Vercel cron forwards as `Authorization: Bearer <CRON_SECRET>`.
# Generate via `openssl rand -hex 32`. Mark Sensitive in Vercel.
CRON_SECRET=
# --- E2E test bridge (plan 06-04 task 3) ---------------------------------
# Required for the /api/e2e-login bridge used by the Playwright suites.
# Absent in production by design — never set this in any Vercel environment.
#
# After toggling this flag, restart `npm run dev` AND clear apps/web/.next —
# the dev cache holds the old middleware decision and `npm run dev`'s HMR
# does not re-evaluate route-handler env reads.
E2E_AUTH_ENABLED=true
